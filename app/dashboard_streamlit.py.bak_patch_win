    elif modo == "Enviar arquivo Excel":
        upload = st.sidebar.file_uploader("Envie a saída Excel do RMC/vROps", type=["xlsx"])
        if upload is not None:
            temp_dir = PROJECT_ROOT / "data/raw/uploads"; temp_dir.mkdir(parents=True, exist_ok=True)
