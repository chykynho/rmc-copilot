@st.cache_data(show_spinner=True)
def processar_excel(caminho_arquivo: str):
    arquivo = Path(caminho_arquivo)
    df_vms = carregar_aba(arquivo, "VMS_SELECIONADAS")
    df_cpu = carregar_aba(arquivo, "HIST_CPU")
