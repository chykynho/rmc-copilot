def obter_colunas_vm_por_recurso(recurso_selecionado: str):
    """
    Define colunas exibidas na tabela de VMs conforme o recurso selecionado.
    """

    colunas_base = [
        "cluster",
        "vm",
        "categoria_vm",
        "status_geral",
        "risco_futuro_90d",
        "criticidade_futura",
        "score_prioridade",
        "prioridade_final",
        "acao_final",
    ]

    if recurso_selecionado == "CPU":
        colunas_recurso = [
            "status_cpu",
            "cpu_media_pct",
            "cpu_p95_pct",
            "cpu_max_pct",
            "cpu_forecast_30d",
            "cpu_forecast_60d",
            "cpu_forecast_90d",
        ]

    elif recurso_selecionado == "Memória":
        colunas_recurso = [
            "status_memoria",
            "mem_media_pct",
            "mem_p95_pct",
            "mem_max_pct",
            "mem_forecast_30d",
            "mem_forecast_60d",
            "mem_forecast_90d",
        ]

    elif recurso_selecionado == "Disco":
        colunas_recurso = [
            "status_disco",
            "disk_media_pct",
            "disk_p95_pct",
            "disk_max_pct",
            "disk_forecast_30d",
            "disk_forecast_60d",
            "disk_forecast_90d",
        ]

    else:
        colunas_recurso = [
            "status_cpu",
            "cpu_p95_pct",
            "cpu_forecast_90d",
            "status_memoria",
            "mem_p95_pct",
            "mem_forecast_90d",
            "status_disco",
            "disk_p95_pct",
            "disk_forecast_90d",
        ]

    colunas_finais = colunas_base + colunas_recurso + ["recomendacao_final"]

    return colunas_finais


