def criar_grafico_vm_historico_forecast(
    df_hist: pd.DataFrame,
    row_vm: pd.Series
):
    """
    Cria gráfico de desempenho coletado + forecast 30/60/90 dias.

    Versão corrigida:
    - Plota histórico real de CPU, memória e disco.
    - Conecta o último ponto real ao forecast 30/60/90.
    - Mostra forecast como linha tracejada.
    """

    fig = go.Figure()

    if df_hist.empty:
        fig.update_layout(
            title="Histórico não disponível para esta VM",
            height=520,
            paper_bgcolor="white",
            plot_bgcolor="white",
        )
        return fig

    df_hist = df_hist.copy()
    df_hist["date"] = pd.to_datetime(df_hist["date"], errors="coerce")
    df_hist["used_pct"] = pd.to_numeric(df_hist["used_pct"], errors="coerce")
    df_hist = df_hist.dropna(subset=["date", "used_pct", "recurso"])

    cores = {
        "CPU": "#2E5B9A",
        "MEMORIA": "#F08A24",
        "DISCO": "#D9534F",
    }

    nomes = {
        "CPU": "CPU coletada",
        "MEMORIA": "Memória coletada",
        "DISCO": "Disco coletado",
    }

    forecast_cols = {
        "CPU": {
            30: "cpu_forecast_30d",
            60: "cpu_forecast_60d",
            90: "cpu_forecast_90d",
        },
        "MEMORIA": {
            30: "mem_forecast_30d",
            60: "mem_forecast_60d",
            90: "mem_forecast_90d",
        },
        "DISCO": {
            30: "disk_forecast_30d",
            60: "disk_forecast_60d",
            90: "disk_forecast_90d",
        },
    }

    for recurso in ["CPU", "MEMORIA", "DISCO"]:
        dados = df_hist[df_hist["recurso"] == recurso].sort_values("date")

        if dados.empty:
            continue

        # Linha histórica real
        fig.add_trace(
            go.Scatter(
                x=dados["date"],
                y=dados["used_pct"],
                mode="lines",
                name=nomes.get(recurso, recurso),
                line=dict(
                    color=cores.get(recurso, "#2E5B9A"),
                    width=2,
                ),
            )
        )

        # Último ponto real para ancorar o forecast
        ultima_data = dados["date"].max()
        ultimo_valor = dados.loc[dados["date"].idxmax(), "used_pct"]

        xs_forecast = [ultima_data]
        ys_forecast = [float(ultimo_valor)]

        for dias, coluna_forecast in forecast_cols[recurso].items():
            valor_forecast = row_vm.get(coluna_forecast)

            if pd.notna(valor_forecast):
                xs_forecast.append(ultima_data + pd.Timedelta(days=dias))
                ys_forecast.append(float(valor_forecast))

        # Só desenha forecast se houver pelo menos 1 ponto futuro
        if len(xs_forecast) > 1:
            fig.add_trace(
                go.Scatter(
                    x=xs_forecast,
                    y=ys_forecast,
                    mode="lines+markers",
                    name=f"{recurso} forecast",
                    line=dict(
                        color=cores.get(recurso, "#2E5B9A"),
                        width=3,
                        dash="dash",
                    ),
                    marker=dict(
                        size=8,
                        symbol="circle",
                    ),
                )
            )

    # Linha de atenção
    fig.add_hline(
        y=85,
        line_dash="dot",
        line_color="#D9A441",
        annotation_text="Atenção 85%",
        annotation_position="top left",
    )

    # Linha crítica
    fig.add_hline(
        y=95,
        line_dash="dot",
        line_color="#D9534F",
        annotation_text="Crítico 95%",
        annotation_position="top left",
    )

    nome_vm = row_vm.get("vm", "VM")

    fig.update_layout(
        title=f"Desempenho coletado + forecast — {nome_vm}",
        xaxis_title="Data",
        yaxis_title="Utilização %",
        height=600,
        paper_bgcolor="white",
        plot_bgcolor="white",
        title_font=dict(size=18, color="#1F3B73"),
        font=dict(color="#374151"),
        legend_title="Recurso",
        margin=dict(l=20, r=20, t=60, b=40),
        hovermode="x unified",
    )

    fig.update_yaxes(
        range=[0, 105],
        gridcolor="#E5EDF7",
    )

    fig.update_xaxes(
        showgrid=False,
    )

    return fig

def carregar_dados_dashboard():
    st.sidebar.markdown("### Fonte de dados")
    modo = st.sidebar.radio("Como carregar os dados?", ["Ler última execução do banco", "Selecionar execução do banco", "Usar arquivo padrão", "Enviar arquivo Excel"])
